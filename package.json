{
  "name": "matchday",
  "version": "1.9.30",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo-google-fonts/saira-condensed": "^0.4.1",
    "@expo-google-fonts/sora": "^0.4.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-community/netinfo": "12.0.1",
    "@supabase/supabase-js": "^2.108.2",
    "babel-preset-expo": "^56.0.15",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-image": "~56.0.11",
    "expo-image-manipulator": "~56.0.20",
    "expo-image-picker": "^56.0.18",
    "expo-linking": "~56.0.14",
    "expo-media-library": "^56.0.7",
    "expo-router": "~56.2.11",
    "expo-sharing": "~56.0.18",
    "expo-status-bar": "~56.0.4",
    "html2canvas": "^1.4.1",
    "i18next": "^26.3.1",
    "jest": "~29.7.0",
    "react": "19.2.3",
    "react-dom": "^19.2.3",
    "react-error-boundary": "^6.1.2",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^4.3.1",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-view-shot": "^5.1.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@react-native/jest-preset": "0.85.3",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/react-native-web-vite": "^10.4.6",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "eslint-plugin-storybook": "^10.4.6",
    "jest-expo": "~56.0.0",
    "storybook": "^10.4.6",
    "test-renderer": "^1.2.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16"
  },
  "scripts": {
    "postinstall": "npx playwright install chromium",
    "proxy": "node scripts/anthropic-proxy.js",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "EXPO_WEB_BUILD=true expo export --platform web",
    "serve:web": "npx serve dist",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test --grep @smoke",
    "e2e:smoke:watch": "SLOWMO=1500 playwright test --grep @smoke --headed --workers=1",
    "e2e:ui": "playwright test --ui",
    "storybook:dev": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "expo lint"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(-google-fonts)?/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|native-base|react-native-svg|@supabase/.*)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "setupFiles": [
      "./node_modules/@react-native/jest-preset/jest/setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "haste": {
      "defaultPlatform": "ios",
      "platforms": [
        "android",
        "ios",
        "native"
      ]
    },
    "resolver": "./node_modules/@react-native/jest-preset/jest/resolver.js"
  },
  "private": true
}
