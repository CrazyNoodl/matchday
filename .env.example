EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-your-key-here
# Only needed for production web builds (GitHub Pages). Points at the
# deployed Cloudflare Worker, see cloudflare-worker/anthropic-proxy.js.
EXPO_PUBLIC_ANTHROPIC_PROXY_URL=https://matchday-anthropic-proxy.your-subdomain.workers.dev
# Product analytics (Aptabase). initAnalytics() no-ops entirely if unset —
# safe to leave blank on a fresh worktree.
EXPO_PUBLIC_APTABASE_APP_KEY=A-EU-0000000000
